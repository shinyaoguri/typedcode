{
  "name": "@typedcode/verify-cli",
  "version": "1.0.0",
  "description": "CLI tool to verify TypedCode typing proof files",
  "type": "module",
  "bin": {
    "typedcode-verify": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@typedcode/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typedcode",
    "typing-proof",
    "verification",
    "cli"
  ],
  "license": "MIT"
}
