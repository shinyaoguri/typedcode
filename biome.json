{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/coverage",
      "!**/playwright-report",
      "!**/test-results",
      "!**/worker-configuration.d.ts",
      "!packages/shared/src/checkpointKeys/localKeys.ts",
      "!packages/shared/src/examAuthorityKeys/localKeys.ts",
      "!packages/e2e/.artifacts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noTemplateCurlyInString": "off",
        "useIterableCallbackReturn": "warn",
        "noAssignInExpressions": "warn",
        "noImplicitAnyLet": "warn",
        "noControlCharactersInRegex": "warn",
        "noNonNullAssertedOptionalChain": "warn"
      },
      "complexity": {
        "noImportantStyles": "off",
        "useLiteralKeys": "off",
        "noThisInStatic": "off",
        "noStaticOnlyClass": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off"
      }
    }
  }
}
